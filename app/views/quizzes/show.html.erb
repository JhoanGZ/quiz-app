<div style="max-width: 860px; margin: 0 auto;">

  <!-- Header -->
  <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 32px;">
    <div>
      <%= link_to "← Volver", quizzes_path, style: "font-size: 13px; color: #667eea; text-decoration: none; font-weight: 600; display: block; margin-bottom: 12px;" %>
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
        <h1 style="font-size: 28px; font-weight: bold; color: #1a1a2e;"><%= @quiz.title %></h1>
        <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 4px 10px; border-radius: 20px;
          <%= @quiz.published? ? 'background: #e8f5e9; color: #2e7d32;' : 'background: #fff3e0; color: #e65100;' %>">
          <%= @quiz.published? ? "✓ Publicado" : "⏸ Borrador" %>
        </span>
      </div>
      <% if @quiz.description.present? %>
        <p style="color: #777; font-size: 15px;"><%= @quiz.description %></p>
      <% end %>
    </div>

    <% if current_user.admin? && @quiz.user_id == current_user.id %>
      <div style="display: flex; gap: 8px;">
        <% if @quiz.draft? %>
          <%= button_to "Publicar", publish_quiz_path(@quiz), method: :patch,
              style: "padding: 10px 20px; background: #e8f5e9; color: #2e7d32; border-radius: 8px; border: none; font-size: 13px; font-weight: 600; cursor: pointer;" %>
        <% end %>
        <%= link_to "Editar", edit_quiz_path(@quiz),
            style: "padding: 10px 20px; background: #f0f0f8; color: #667eea; border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600;" %>
        <%= button_to "Eliminar", quiz_path(@quiz), method: :delete,
            form: { data: { turbo_confirm: "¿Estás seguro? Esta acción no se puede deshacer." } },
            style: "padding: 10px 20px; background: #fdecea; color: #c62828; border-radius: 8px; border: none; font-size: 13px; font-weight: 600; cursor: pointer;" %>
      </div>
    <% end %>
  </div>

  <!-- Stats -->
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 32px;">
    <div style="background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); text-align: center;">
      <div style="font-size: 28px; font-weight: bold; color: #667eea;"><%= @quiz.questions.count %></div>
      <div style="font-size: 13px; color: #888; margin-top: 4px;">Preguntas</div>
    </div>
    <div style="background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); text-align: center;">
      <div style="font-size: 28px; font-weight: bold; color: #764ba2;"><%= @quiz.passing_score %>%</div>
      <div style="font-size: 13px; color: #888; margin-top: 4px;">Puntaje mínimo</div>
    </div>
    <div style="background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); text-align: center;">
      <div style="font-size: 28px; font-weight: bold; color: #f093fb;"><%= @quiz.attempts.count %></div>
      <div style="font-size: 13px; color: #888; margin-top: 4px;">Intentos</div>
    </div>
  </div>

  <!-- Video embed -->
  <% if @quiz.video_url.present? %>
    <div style="background: white; border-radius: 12px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 24px;">
      <h3 style="font-size: 15px; font-weight: 700; color: #1a1a2e; margin-bottom: 16px;">🎬 Video del quiz</h3>
      <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 8px;">
        <iframe src="<%= @quiz.video_url.gsub('watch?v=', 'embed/').gsub('youtu.be/', 'www.youtube.com/embed/') %>"
                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                frameborder="0" allowfullscreen></iframe>
      </div>
    </div>
  <% end %>

  <!-- Questions - admin only -->
  <% if current_user.admin? %>
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
      <h2 style="font-size: 20px; font-weight: bold; color: #1a1a2e;">Preguntas</h2>
      <% if @quiz.user_id == current_user.id %>
        <%= link_to "＋ Agregar pregunta", new_quiz_question_path(@quiz),
            style: "background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 13px;" %>
      <% end %>
    </div>

    <% if @quiz.questions.empty? %>
      <div style="text-align: center; padding: 60px 0; color: #aaa; background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
        <div style="font-size: 48px; margin-bottom: 12px;">❓</div>
        <p style="font-size: 16px; font-weight: 600; color: #555;">No hay preguntas todavía</p>
        <p style="font-size: 13px; margin-top: 6px;">Agrega la primera con el botón de arriba</p>
      </div>
    <% else %>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        <% @quiz.questions.each_with_index do |question, index| %>
          <div style="background: white; border-radius: 12px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px;">
              <div style="display: flex; gap: 12px; align-items: flex-start;">
                <span style="background: linear-gradient(135deg, #667eea, #764ba2); color: white; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; flex-shrink: 0;">
                  <%= index + 1 %>
                </span>
                <p style="font-size: 15px; font-weight: 600; color: #1a1a2e; line-height: 1.4;"><%= question.body %></p>
              </div>
              <% if @quiz.user_id == current_user.id %>
                <div style="display: flex; gap: 8px; flex-shrink: 0; margin-left: 16px;">
                  <%= link_to "Editar", edit_quiz_question_path(@quiz, question),
                      style: "font-size: 12px; color: #667eea; text-decoration: none; font-weight: 600;" %>
                  <%= button_to "Eliminar", quiz_question_path(@quiz, question), method: :delete,
                      form: { data: { turbo_confirm: "¿Eliminar esta pregunta?" } },
                      style: "font-size: 12px; color: #c62828; background: none; border: none; cursor: pointer; font-weight: 600; padding: 0;" %>
                </div>
              <% end %>
            </div>

            <!-- Options -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-left: 40px;">
              <% question.options.each do |option| %>
                <div style="padding: 10px 14px; border-radius: 8px; font-size: 13px;
                  <%= option.correct? ? 'background: #e8f5e9; color: #2e7d32; font-weight: 600; border: 1px solid #a5d6a7;' : 'background: #f8f8f8; color: #555; border: 1px solid #eee;' %>">
                  <%= option.correct? ? "✓ " : "" %><%= option.body %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <!-- Start quiz button (players only, published quizzes) -->
  <% if current_user.player? && @quiz.published? %>
    <% existing_attempt = @quiz.attempts.find_by(user_id: current_user.id) %>
    <div style="text-align: center; margin-top: 40px;">
      <% if existing_attempt %>
        <!-- Player already attempted this quiz -->
        <div style="background: #fff3e0; border-radius: 12px; padding: 24px; display: inline-block;">
          <p style="color: #e65100; font-weight: 600; margin-bottom: 12px;">Ya realizaste este quiz</p>
          <%= link_to "Ver mi resultado", attempt_path(existing_attempt),
              style: "padding: 12px 28px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 10px; text-decoration: none; font-size: 14px; font-weight: 600;" %>
        </div>
      <% else %>
        <%= button_to "🎯 Iniciar Quiz", attempts_path, method: :post,
            params: { attempt: { quiz_id: @quiz.id } },
            style: "padding: 16px 48px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 12px; font-size: 18px; font-weight: bold; cursor: pointer; box-shadow: 0 4px 15px rgba(102,126,234,0.4);" %>
      <% end %>
    </div>
  <% end %>

</div>
