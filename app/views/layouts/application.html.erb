<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Quiz App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <% if user_signed_in? %>
      <nav class="bg-white shadow">
        <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
          <a href="/" class="text-xl font-bold text-indigo-600">Quiz App</a>
          <div class="flex items-center gap-4">
            <span class="text-sm text-gray-600">
              <%= current_user.email %> (<%= current_user.role %>)
            </span>
            <%= button_to "Cerrar sesión", destroy_user_session_path, method: :delete, class: "text-sm text-red-600 hover:underline", style: "background: none; border: none; cursor: pointer; padding: 0;" %>
          </div>
        </div>
      </nav>
      <% if notice %>
        <div class="max-w-7xl mx-auto px-4 mt-4">
          <div class="bg-green-100 text-green-800 px-4 py-2 rounded"><%= notice %></div>
        </div>
      <% end %>
      <% if alert %>
        <div class="max-w-7xl mx-auto px-4 mt-4">
          <div class="bg-red-100 text-red-800 px-4 py-2 rounded"><%= alert %></div>
        </div>
      <% end %>
      <main class="max-w-7xl mx-auto px-4 py-6">
        <%= yield %>
      </main>
    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>
